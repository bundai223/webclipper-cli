{
	"schemaVersion": "0.1.0",
	"name": "Zenn",
	"behavior": "create",
	"noteContentFormat": "{{content}}",
	"properties": [
		{
			"name": "title",
			"value": "{{title}}",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "author",
			"value": "{{selector:article > aside > div > div > div >  a}}",
			"type": "multitext"
		},
		{
			"name": "published",
			"value": "{{published}}",
			"type": "date"
		},
		{
			"name": "created",
			"value": "{{date}}",
			"type": "date"
		},
		{
			"name": "description",
			"value": "{{description}}",
			"type": "text"
		},
		{
			"name": "tags",
			"value": "clippings,ingest-pending",
			"type": "multitext"
		}
	],
	"triggers": [
		"https://zenn.dev/*/articles/*"
	],
	"noteNameFormat": "{{title}}",
	"path": "Literature Notes/raw/posts/"
}